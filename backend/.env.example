SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here
DATABASE_URL=sqlite:///draftly.db
MCP_API_KEY=your-mcp-api-key
OAUTH_CLIENT_ID=docsly-openai-client
OAUTH_CLIENT_SECRET=docsly-openai-secret
# Comma-separated allowed OAuth redirect URIs
OAUTH_REDIRECT_ALLOWLIST=http://localhost:3000/callback
# Testing shortcut only (do not use in production): allow any redirect_uri
OAUTH_ALLOW_ANY_REDIRECT=false
